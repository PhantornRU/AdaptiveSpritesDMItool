            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="MinWidth" Value="72" />
        </Style>
        <DataTemplate x:Key="SourceCellTemplate">
            <Button Width="10" Height="10" Margin="0.25" Padding="0" Background="{Binding Fill}" BorderBrush="{Binding Border}" BorderThickness="1" Content="{Binding Caption}" Foreground="{Binding Foreground}" FontSize="6" ToolTip="{Binding ToolTip}" PreviewMouseLeftButtonDown="SourceCellButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="SourceCellButton_PreviewMouseLeftButtonUp" MouseEnter="SourceCellButton_MouseEnter" />
        </DataTemplate>
        <DataTemplate x:Key="TargetCellTemplate">
            <Button Width="10" Height="10" Margin="0.25" Padding="0" Background="{Binding Fill}" BorderBrush="{Binding Border}" BorderThickness="1" Content="{Binding Caption}" Foreground="{Binding Foreground}" FontSize="6" ToolTip="{Binding ToolTip}" PreviewMouseLeftButtonDown="TargetCellButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="TargetCellButton_PreviewMouseLeftButtonUp" MouseEnter="TargetCellButton_MouseEnter" />
        </DataTemplate>
        <DataTemplate x:Key="PreviewCellTemplate">
            <Border Width="8" Height="8" Margin="0.25" Background="{Binding Fill}" BorderBrush="{Binding Border}" BorderThickness="1" ToolTip="{Binding ToolTip}">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="5" Text="{Binding Caption}" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="DirectionNavigatorPreviewCellTemplate">
            <Border Width="4"
                    Height="4"
                    Margin="0"
                    Padding="0"
                    Background="{Binding Fill}"
                    BorderBrush="{Binding Border}"
                    BorderThickness="0"
                    ToolTip="{Binding ToolTip}" />
        </DataTemplate>
        <DataTemplate x:Key="DirectionNavigatorItemTemplate">
            <Grid MinHeight="56">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="60" Height="60" Padding="2" Background="{DynamicResource Brush.ControlBackground}" CornerRadius="6">
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" />
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Label}" />
                    <TextBlock FontSize="10" Foreground="{DynamicResource Brush.TextSecondary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Select direction" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Text" Value="Active direction" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="HorizontalDirectionStripItemTemplate">
            <Grid MinWidth="72" MinHeight="52">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Width="38" Height="38" HorizontalAlignment="Center" Padding="2" Background="{DynamicResource Brush.ControlBackground}" CornerRadius="6">
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" />
                </Border>
                <TextBlock Grid.Row="1" Margin="0,4,0,0" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="{Binding Label}" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="SidebarDirectionItemTemplate">
            <Grid MinHeight="38" ToolTip="{Binding Label}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="28" Height="28" Padding="1" Background="{DynamicResource Brush.ControlBackground}" CornerRadius="4">
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" />
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextPrimary}"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="9"
                               Foreground="{DynamicResource Brush.TextSecondary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Select direction" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsScopeAffected}" Value="True">
                                        <Setter Property="Text" Value="Affected by scope" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Text" Value="Active direction" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="StateSidebarItemTemplate">
            <Grid MinHeight="46">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" Background="{DynamicResource Brush.SurfaceSubtle}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="17">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextSecondary}" Text="S" />
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Text="{Binding}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="10" Foreground="{DynamicResource Brush.TextSecondary}" Text="{DynamicResource Text.StatePool}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SourceViewportSurfaceTemplate">
            <Border Margin="2"
                    Padding="3"
                    Background="{DynamicResource Brush.ControlBackground}"
                    BorderBrush="{DynamicResource Brush.PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="7">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DataContext.EditorWorkspace.IsSourceReferenceDimmed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter Property="Opacity" Value="0.45" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Margin="0,0,0,2"
                               HorizontalAlignment="Center"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="{Binding Label}" />
                    <local:EditorSurfaceControl Grid.Row="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Surface="{Binding Surface}"
                                                Zoom="{Binding DataContext.EditorWorkspace.ActiveEditorZoom, RelativeSource={RelativeSource AncestorType=Window}}"
                                                ShowGrid="{Binding DataContext.EditorWorkspace.ShowGrid, RelativeSource={RelativeSource AncestorType=Window}}"
                                                ShowCaptions="{Binding DataContext.EditorWorkspace.ShowGridCaptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                SelectedSourceCoordinate="{Binding DataContext.EditorWorkspace.SelectedSourceCoordinate, RelativeSource={RelativeSource AncestorType=Window}}"
                                                HoveredCoordinate="{Binding DataContext.EditorWorkspace.SourceHoveredCoordinate, RelativeSource={RelativeSource AncestorType=Window}}"
                                                HighlightedCoordinates="{Binding DataContext.EditorWorkspace.SourceLinkedHoverCoordinates, RelativeSource={RelativeSource AncestorType=Window}}"
                                                PreviewMouseLeftButtonDown="SourceSurface_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="SourceSurface_PreviewMouseLeftButtonUp"
                                                MouseMove="SourceSurface_MouseMove"
                                                MouseLeave="SourceSurface_MouseLeave" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="EditableViewportSurfaceTemplate">
            <Border Margin="2"
                    Padding="3"
                    Background="{DynamicResource Brush.ControlBackground}"
                    BorderBrush="{DynamicResource Brush.PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="7">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Margin="0,0,0,2"
                               HorizontalAlignment="Center"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="{Binding Label}" />
                    <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <local:EditorSurfaceControl HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Surface="{Binding Surface}"
                                                    Zoom="{Binding DataContext.EditorWorkspace.ActiveEditorZoom, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    ShowGrid="{Binding DataContext.EditorWorkspace.ShowGrid, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    ShowCaptions="{Binding DataContext.EditorWorkspace.ShowGridCaptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    SelectedTargetCoordinate="{Binding DataContext.EditorWorkspace.SelectedTargetCoordinate, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    SelectedAreaBounds="{Binding DataContext.EditorWorkspace.SelectedAreaBounds, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    HoveredCoordinate="{Binding DataContext.EditorWorkspace.EditableHoveredCoordinate, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    HighlightedCoordinates="{Binding DataContext.EditorWorkspace.EditableLinkedHoverCoordinates, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    PreviewMouseLeftButtonDown="TargetSurface_PreviewMouseLeftButtonDown"
                                                    MouseMove="TargetSurface_MouseMove"
                                                    MouseLeave="TargetSurface_MouseLeave"
                                                    LostMouseCapture="TargetSurface_LostMouseCapture"
                                                    PreviewMouseLeftButtonUp="TargetSurface_PreviewMouseLeftButtonUp" />
                        <local:EditorSurfaceControl HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    IsHitTestVisible="False"
                                                    Opacity="0.35"
                                                    Visibility="{Binding DataContext.EditorWorkspace.ShowOverlayCompareLayer, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Surface="{Binding OverlaySurface}"
                                                    Zoom="{Binding DataContext.EditorWorkspace.ActiveEditorZoom, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    ShowGrid="False"
                                                    ShowCaptions="False" />
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DirectionTileTemplate">
            <Border Margin="0,0,4,4" Padding="4" Background="{DynamicResource Brush.CardBackground}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Label}" />
                    <Grid Grid.Row="1" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="6" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Padding="3" Background="{DynamicResource Brush.SurfaceSubtle}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="7">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextSecondary}" Text="{DynamicResource Text.Source}" />
                                <Viewbox Grid.Row="1" Margin="0,3,0,0" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ItemsControl ItemsSource="{Binding SourceRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding Cells}" ItemTemplate="{StaticResource SourceCellTemplate}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Viewbox>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Padding="3" Background="{DynamicResource Brush.ControlBackground}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="7">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextSecondary}" Text="{DynamicResource Text.Editable}" />
                                <Viewbox Grid.Row="1" Margin="0,3,0,0" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ItemsControl ItemsSource="{Binding TargetRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding Cells}" ItemTemplate="{StaticResource TargetCellTemplate}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Viewbox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="6">
        <Border DockPanel.Dock="Bottom" Padding="8,5" Background="{DynamicResource Brush.PanelBackground}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditorSectionSelected}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid DataContext="{Binding OperationalStatusBar}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Text="{Binding StatusMessage}" />
                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" Text="{Binding CurrentStateSummary}" />
                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" Text="{Binding ActiveDirection, StringFormat=Dir {0}}" />
                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" Text="{Binding MappingSummary}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" Text="{Binding BatchSummary}" />
                    <ProgressBar Width="180" Height="8" Margin="0,0,10,0" VerticalAlignment="Center"
                                 IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                                 Maximum="{Binding OperationProgressMaximum, Mode=OneWay}"
                                 Value="{Binding OperationProgressValue, Mode=OneWay}" />
                    <Button Style="{StaticResource ThemedButtonStyle}" Padding="10,4" Command="{Binding CancelCommand}" Content="{DynamicResource Text.Cancel}" />
                </StackPanel>
            </Grid>
        </Border>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CompactPanelBorderStyle}" Padding="0,4">
                <ListBox DataContext="{Binding NavigationRail}"
                         ItemsSource="{Binding Items}"
                         SelectedValuePath="Section"
                         SelectedValue="{Binding SelectedSection, Mode=TwoWay}"
                          Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource RailListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ToolTip="{Binding Label}"
                                  AutomationProperties.Name="{Binding Label}">
                                <ui:SymbolIcon Style="{StaticResource RailSymbolIconStyle}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                               HorizontalAlignment="Center"
                                               Symbol="{Binding IconSymbol}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="0,0,0,6">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ThinHeaderStripStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditorSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="20" Height="20" Margin="0,0,8,0" Source="pack://application:,,,/Assets/Brand/AdaptiveToolLogo.png" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="{Binding WorkspaceTitle}" />
                                <StackPanel Margin="0,1,0,0" Orientation="Horizontal">
                                    <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="{Binding SpriteContractSummary}" />
                                    <TextBlock Margin="10,0,0,0" Foreground="{DynamicResource Brush.TextSecondary}" Text="{Binding ConfigSummary}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Margin="0,0,6,0" Style="{StaticResource CompactActionButtonStyle}" Command="{Binding OpenDmiCommand}" Content="{DynamicResource Text.OpenDmi}" />
                            <Button Style="{StaticResource CompactActionButtonStyle}" Command="{Binding SaveConfigCommand}" Content="{DynamicResource Text.SaveConfig}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CompactPanelBorderStyle}">
                    <TabControl Style="{StaticResource ShellTabControlStyle}" SelectedIndex="{Binding SelectedShellSectionIndex, Mode=TwoWay}">
                <TabItem Header="{DynamicResource Text.Tab.Start}">
                    <Grid DataContext="{Binding StartTab}" Margin="8">
                        <Border MaxWidth="488" Padding="16" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" Background="{DynamicResource Brush.CardBackground}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="18">
                            <StackPanel>
                                <TextBlock FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           Text="{Binding WelcomeTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap" Text="{Binding WelcomeBody}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ResumeEditorHint}" />

                                <Button Margin="0,12,0,0" Command="{Binding ContinueToEditorCommand}" Content="{DynamicResource Text.ContinueEditor}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource StartPrimaryButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowContinueEditorAction}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Margin="0,12,0,0" Command="{Binding OpenDmiCommand}" Content="{DynamicResource Text.OpenDmi}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource StartPrimaryButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowOpenDmiPrimaryAction}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Border Margin="0,10,0,0" Padding="10" Background="{DynamicResource Brush.PanelBackground}" CornerRadius="12" Visibility="{Binding ShowCreateConfigAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="{DynamicResource Text.CreateConfigPrompt}" />
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Style="{StaticResource ThemedTextBoxStyle}" Padding="12,7" Text="{Binding DraftConfigName, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="1" Style="{StaticResource ThemedButtonStyle}" Width="140" Margin="10,0,0,0" Padding="12,7" Command="{Binding CreateConfigCommand}" Content="{DynamicResource Text.CreateConfig}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <UniformGrid Margin="0,8,0,0" Columns="3">
                                    <Button Margin="0,0,6,0" Command="{Binding OpenDmiCommand}" Content="{DynamicResource Text.OpenDmi}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource StartSecondaryButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowCreateConfigAction}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Margin="0,0,6,0" Style="{StaticResource StartSecondaryButtonStyle}" Command="{Binding LoadConfigCommand}" Content="{DynamicResource Text.LoadJson}" />
                                    <Button Margin="0" Style="{StaticResource StartSecondaryButtonStyle}" Command="{Binding ImportLegacyConfigCommand}" Content="{DynamicResource Text.ImportCsv}" />
                                </UniformGrid>

                                <Expander Margin="0,12,0,0" Style="{StaticResource ThemedExpanderStyle}" Header="{DynamicResource Text.RecentPaths}" Visibility="{Binding ShowRecentPaths, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Margin="0,8,0,0">
                                        <Button Padding="10,7" Command="{Binding ResumeLastWorkspaceCommand}" Content="{DynamicResource Text.ResumeLastWorkspace}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource StartSecondaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRecentWorkspace}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Margin="0,6,0,0"
                                                Padding="10,7"
                                                Style="{StaticResource StartSecondaryButtonStyle}"
                                                Command="{Binding OpenRecentDmiCommand}"
                                                IsEnabled="{Binding HasRecentDmi}">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                                           Text="{DynamicResource Text.OpenLastDmi}" />
                                                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" TextWrapping="Wrap" Text="{Binding LastDmiPathSummary}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Margin="0,6,0,0"
                                                Padding="10,7"
                                                Style="{StaticResource StartSecondaryButtonStyle}"
                                                Command="{Binding OpenRecentConfigCommand}"
                                                IsEnabled="{Binding HasRecentConfig}">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                                           Text="{DynamicResource Text.LoadLastJsonConfig}" />
                                                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" TextWrapping="Wrap" Text="{Binding LastConfigPathSummary}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Margin="0,6,0,0"
                                                Padding="10,7"
                                                Style="{StaticResource StartSecondaryButtonStyle}"
                                                Command="{Binding ImportRecentLegacyCsvCommand}"
                                                IsEnabled="{Binding HasRecentLegacyCsv}">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                                           Text="{DynamicResource Text.ImportLastLegacyCsv}" />
                                                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" TextWrapping="Wrap" Text="{Binding LastLegacyImportSummary}" />
                                            </StackPanel>
                                        </Button>
                                        <DockPanel Margin="0,8,0,0" LastChildFill="True">
                                            <Button DockPanel.Dock="Right" Style="{StaticResource ThemedButtonStyle}" Margin="12,0,0,0" Padding="12,7" Command="{Binding ResetWorkspaceCommand}" Content="{DynamicResource Text.Reset}" />
                                            <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" TextWrapping="Wrap" Text="{Binding LastBatchOutputSummary}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource Text.Tab.Editor}" IsEnabled="{Binding EditorWorkspace.IsAvailable}">
                    <Grid Margin="2" DataContext="{Binding EditorWorkspace}">
                        <Grid.RowDefinitions>
