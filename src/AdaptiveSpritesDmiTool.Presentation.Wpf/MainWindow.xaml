<Window x:Class="AdaptiveSpritesDmiTool.Presentation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1360"
        Height="860"
        MinWidth="1120"
        MinHeight="720"
        Background="{StaticResource Brush.WindowBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,18"
                Padding="20"
                Background="{StaticResource Brush.PanelBackground}"
                BorderBrush="{StaticResource Brush.PanelBorder}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Text="Adaptive Sprites DMI Tool" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Text="Empty workspace first. The shell executes open, save, load, import, and preview flows without direct file logic in code-behind." />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Margin="0,0,12,12"
                            Padding="18,10"
                            Command="{Binding OpenDmiCommand}"
                            Content="Open DMI" />
                    <Button Margin="0,0,12,12"
                            Padding="18,10"
                            Command="{Binding CreateConfigCommand}"
                            Content="Create Config" />
                    <Button Margin="0,0,12,12"
                            Padding="18,10"
                            Command="{Binding SaveConfigCommand}"
                            Content="Save Config" />
                    <Button Margin="0,0,12,12"
                            Padding="18,10"
                            Command="{Binding LoadConfigCommand}"
                            Content="Load Config" />
                    <Button Margin="0,0,12,12"
                            Padding="18,10"
                            Command="{Binding ImportLegacyConfigCommand}"
                            Content="Import CSV" />
                    <Button Padding="18,10"
                            Command="{Binding ResetWorkspaceCommand}"
                            Content="Reset Workspace" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Padding="14"
                Background="{StaticResource Brush.PanelBackground}"
                BorderBrush="{StaticResource Brush.PanelBorder}"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           Text="{Binding StatusMessage}" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Width="160"
                                 Height="10"
                                 Margin="0,0,12,0"
                                 IsIndeterminate="True" />
                    <Button Padding="12,6"
                            Command="{Binding CancelCommand}"
                            Content="Cancel" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="1.35*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,18"
                    Padding="18"
                    Background="{StaticResource Brush.PanelBackground}"
                    BorderBrush="{StaticResource Brush.PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Foreground="{StaticResource Brush.TextSecondary}" Text="Workspace" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="{Binding WorkspaceTitle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Foreground="{StaticResource Brush.TextSecondary}" Text="Sprite Contract" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="16"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="{Binding SpriteContractSummary}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Foreground="{StaticResource Brush.TextSecondary}" Text="Config State" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="16"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="{Binding ConfigSummary}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,18,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.45*" />
                    <RowDefinition Height="0.9*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,18"
                        Padding="18"
                        Background="{StaticResource Brush.PanelBackground}"
                        BorderBrush="{StaticResource Brush.PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="Preview Staging" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="{Binding PreviewSelectionSummary}" />

                        <Grid Grid.Row="2" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Foreground="{StaticResource Brush.TextSecondary}" Text="Base state" />
                                <TextBox Margin="0,8,0,0"
                                         Padding="10,8"
                                         Text="{Binding BaseStateName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0">
                                <TextBlock Foreground="{StaticResource Brush.TextSecondary}" Text="Landmark state" />
                                <TextBox Margin="0,8,0,0"
                                         Padding="10,8"
                                         Text="{Binding LandmarkStateName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="12,0">
                                <TextBlock Foreground="{StaticResource Brush.TextSecondary}" Text="Overlay state" />
                                <TextBox Margin="0,8,0,0"
                                         Padding="10,8"
                                         Text="{Binding OverlayStateName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Button Grid.Column="3"
                                    Margin="16,24,0,0"
                                    Padding="16,8"
                                    VerticalAlignment="Top"
                                    Command="{Binding StagePreviewSelectionCommand}"
                                    Content="Build Preview" />
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Margin="0,0,12,12"
                                    CornerRadius="14"
                                    Background="{StaticResource Brush.AccentMuted}">
                                <StackPanel Margin="16">
                                    <TextBlock FontWeight="SemiBold" Text="Base State" />
                                    <Border Margin="0,12,0,0"
                                            Height="164"
                                            CornerRadius="12"
                                            Background="#FFF9F2">
                                        <Viewbox Stretch="Uniform">
                                            <Image Source="{Binding BasePreviewImage}"
                                                   Stretch="None"
                                                   SnapsToDevicePixels="True" />
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               Text="{Binding BasePreviewText}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="12,0,0,12"
                                    CornerRadius="14"
                                    Background="#F0E8DA">
                                <StackPanel Margin="16">
                                    <TextBlock FontWeight="SemiBold" Text="Landmark" />
                                    <Border Margin="0,12,0,0"
                                            Height="164"
                                            CornerRadius="12"
                                            Background="#FFF9F2">
                                        <Viewbox Stretch="Uniform">
                                            <Image Source="{Binding LandmarkPreviewImage}"
                                                   Stretch="None"
                                                   SnapsToDevicePixels="True" />
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               Text="{Binding LandmarkPreviewText}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Margin="0,12,12,0"
                                    CornerRadius="14"
                                    Background="#ECE3D7">
                                <StackPanel Margin="16">
                                    <TextBlock FontWeight="SemiBold" Text="Overlay" />
                                    <Border Margin="0,12,0,0"
                                            Height="164"
                                            CornerRadius="12"
                                            Background="#FFF9F2">
                                        <Viewbox Stretch="Uniform">
                                            <Image Source="{Binding OverlayPreviewImage}"
                                                   Stretch="None"
                                                   SnapsToDevicePixels="True" />
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               Text="{Binding OverlayPreviewText}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="12,12,0,0"
                                    CornerRadius="14"
                                    Background="#E6E8D9">
                                <StackPanel Margin="16">
                                    <TextBlock FontWeight="SemiBold" Text="Composite" />
                                    <Border Margin="0,12,0,0"
                                            Height="164"
                                            CornerRadius="12"
                                            Background="#FFF9F2">
                                        <Viewbox Stretch="Uniform">
                                            <Image Source="{Binding CompositePreviewImage}"
                                                   Stretch="None"
                                                   SnapsToDevicePixels="True" />
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               Text="{Binding CompositePreviewText}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="18"
                        Background="{StaticResource Brush.PanelBackground}"
                        BorderBrush="{StaticResource Brush.PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="Manual Flow" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="{Binding ManualFlowSummary}" />

                        <Grid Grid.Row="2" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       Text="DMI path" />
                            <TextBox Grid.Column="1"
                                     Margin="16,0"
                                     Padding="10,8"
                                     Text="{Binding PendingDmiPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Padding="16,8"
                                    Command="{Binding OpenDmiCommand}"
                                    Content="Open" />
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       Text="Config name" />
                            <TextBox Grid.Column="1"
                                     Margin="16,0"
                                     Padding="10,8"
                                     Text="{Binding DraftConfigName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Padding="16,8"
                                    Command="{Binding CreateConfigCommand}"
                                    Content="Create" />
                        </Grid>

                        <Grid Grid.Row="4" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       Text="JSON path" />
                            <TextBox Grid.Column="1"
                                     Margin="16,0"
                                     Padding="10,8"
                                     Text="{Binding PendingConfigPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Margin="0,0,10,0"
                                    Padding="16,8"
                                    Command="{Binding LoadConfigCommand}"
                                    Content="Load" />
                            <Button Grid.Column="3"
                                    Padding="16,8"
                                    Command="{Binding SaveConfigCommand}"
                                    Content="Save" />
                        </Grid>

                        <Grid Grid.Row="5" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       Text="Legacy CSV" />
                            <TextBox Grid.Column="1"
                                     Margin="16,0"
                                     Padding="10,8"
                                     Text="{Binding PendingLegacyCsvPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Padding="16,8"
                                    Command="{Binding ImportLegacyConfigCommand}"
                                    Content="Import" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Margin="0,0,0,18"
                        Padding="18"
                        Background="{StaticResource Brush.PanelBackground}"
                        BorderBrush="{StaticResource Brush.PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="Direction Display" />

                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                            <TextBlock Foreground="{StaticResource Brush.TextSecondary}"
                                       Text="{Binding CurrentDirectionText}" />

                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding DirectionBadges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,10,10"
                                                Padding="10,6"
                                                CornerRadius="12"
                                                Background="{StaticResource Brush.AccentMuted}">
                                            <TextBlock Text="{Binding}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="18"
                        Background="{StaticResource Brush.PanelBackground}"
                        BorderBrush="{StaticResource Brush.PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="Blockers And Next Actions" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,14,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="{Binding WorkspaceNotes}" />

                        <ItemsControl Grid.Row="2" Margin="0,18,0,0" ItemsSource="{Binding IntegrationBlockers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8EEE4">
                                        <TextBlock TextWrapping="Wrap" Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Row="3" Margin="0,18,0,0" ItemsSource="{Binding NextActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8F3EC">
                                        <TextBlock TextWrapping="Wrap" Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>