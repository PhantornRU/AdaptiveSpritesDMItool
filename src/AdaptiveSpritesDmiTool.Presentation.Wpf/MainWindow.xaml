                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="Hover:" />
                                                <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding HoverToken}" />
                                            </StackPanel>
