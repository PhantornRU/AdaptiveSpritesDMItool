                            <Border Grid.Column="4"
                                    Background="#FFF9F2"
                                    CornerRadius="8"
                                    Visibility="{Binding ShowRightDirectionStrip, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Border Grid.Column="2"
                                    Padding="8,3"
                                    MinHeight="30"
                                    Background="#FFFDF8EF"
                                    BorderBrush="{StaticResource Brush.PanelBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding ShowBottomStatusBar, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <WrapPanel VerticalAlignment="Center">
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="Dir:" />
                                            <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding ActiveDirectionLabel}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="Asset:" />
                                            <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding CurrentAssetDisplayName}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="Hover:" />
                                            <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding HoverToken}" />
                                        </StackPanel>
