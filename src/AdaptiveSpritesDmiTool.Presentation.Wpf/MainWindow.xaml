<Window x:Class="AdaptiveSpritesDmiTool.Presentation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdaptiveSpritesDmiTool.Presentation.Wpf"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Icon="pack://application:,,,/Assets/Brand/wpfui-icon.ico"
        Width="1460"
        Height="920"
        MinWidth="1200"
        MinHeight="760"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource Brush.WindowBackground}">
    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding SelectEditorToolCommand}" CommandParameter="{x:Static local:EditorTool.Single}" />
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding SelectEditorToolCommand}" CommandParameter="{x:Static local:EditorTool.Fill}" />
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding SelectEditorToolCommand}" CommandParameter="{x:Static local:EditorTool.Move}" />
        <KeyBinding Key="D4" Modifiers="Control" Command="{Binding SelectEditorToolCommand}" CommandParameter="{x:Static local:EditorTool.Select}" />
        <KeyBinding Key="F1" Modifiers="Control" Command="{Binding SelectEditorToolCommand}" CommandParameter="{x:Static local:EditorTool.Delete}" />
        <KeyBinding Key="F2" Modifiers="Control" Command="{Binding SelectEditorToolCommand}" CommandParameter="{x:Static local:EditorTool.Undo}" />
        <KeyBinding Key="F3" Modifiers="Control" Command="{Binding SelectEditorToolCommand}" CommandParameter="{x:Static local:EditorTool.UndoArea}" />
        <KeyBinding Key="D1" Modifiers="Alt" Command="{Binding SelectDirectionScopeCommand}" CommandParameter="{x:Static local:DirectionScope.Single}" />
        <KeyBinding Key="D2" Modifiers="Alt" Command="{Binding SelectDirectionScopeCommand}" CommandParameter="{x:Static local:DirectionScope.Parallel}" />
        <KeyBinding Key="D3" Modifiers="Alt" Command="{Binding SelectDirectionScopeCommand}" CommandParameter="{x:Static local:DirectionScope.All}" />
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding RedoCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <sys:String x:Key="Icon.Tool.Paint">AddSquare20</sys:String>
        <sys:String x:Key="Icon.Tool.Fill">Grid20</sys:String>
        <sys:String x:Key="Icon.Tool.Move">ArrowMove20</sys:String>
        <sys:String x:Key="Icon.Tool.Select">SquareHintApps20</sys:String>
        <sys:String x:Key="Icon.Tool.Delete">Eraser20</sys:String>
        <sys:String x:Key="Icon.Scope.Single">Square20</sys:String>
        <sys:String x:Key="Icon.Scope.Parallel">TableCellsMerge20</sys:String>
        <sys:String x:Key="Icon.Scope.All">Grid20</sys:String>
        <sys:String x:Key="Icon.View.Dual">DualScreenMirror20</sys:String>
        <sys:String x:Key="Icon.View.Overlay">BorderTop20</sys:String>
        <sys:String x:Key="Icon.View.Grid">TableSimple20</sys:String>
        <sys:String x:Key="Icon.View.Layered">SubGrid20</sys:String>
        <sys:String x:Key="Icon.Action.Undo">ArrowHookDownLeft20</sys:String>
        <sys:String x:Key="Icon.Action.Redo">ArrowHookDownRight20</sys:String>
        <sys:String x:Key="Icon.Action.Clear">DismissSquare20</sys:String>
        <sys:String x:Key="Icon.Action.Fit">ArrowAutofitWidthDotted20</sys:String>
        <sys:String x:Key="Icon.Action.Focus">FullScreenMaximize20</sys:String>
        <sys:String x:Key="Icon.Dock.OpenDmi">AppFolder20</sys:String>
        <sys:String x:Key="Icon.Dock.Refresh">ArrowSync20</sys:String>
        <sys:String x:Key="Icon.Dock.Auto">FlashAuto20</sys:String>
        <sys:String x:Key="Icon.Dock.ConfigNew">ReceiptAdd20</sys:String>
        <sys:String x:Key="Icon.Dock.ConfigLoad">FolderOpen20</sys:String>
        <sys:String x:Key="Icon.Dock.ConfigSave">Save24</sys:String>
        <sys:String x:Key="Icon.Dock.ConfigSaveAs">SaveEdit24</sys:String>
        <sys:String x:Key="Icon.Dock.Expand">MoreHorizontal20</sys:String>
        <Style x:Key="ShellModeRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ShellTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" Margin="{TemplateBinding Padding}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StartPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style x:Key="StartSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="DenseToolbarSelectorStyle" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DenseToolbarSelectorItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}" Background="{StaticResource Brush.ControlBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DenseToolbarActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Margin" Value="0,0,3,3" />
        </Style>
        <Style x:Key="CompactPanelBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="{StaticResource Brush.PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="ThinHeaderStripStyle" TargetType="Border" BasedOn="{StaticResource CompactPanelBorderStyle}">
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style x:Key="EditorSectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="CompactActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DenseToolbarActionButtonStyle}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="EditorPrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactActionButtonStyle}">
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="EditorPrimaryToolbarToggleStyle" TargetType="RadioButton" BasedOn="{StaticResource ShellModeRadioButtonStyle}">
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Background" Value="{StaticResource Brush.ControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="LeftDockTabToggleStyle" TargetType="RadioButton" BasedOn="{StaticResource EditorPrimaryToolbarToggleStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                Background="{StaticResource Brush.ControlBackground}"
                                BorderBrush="{StaticResource Brush.PanelBorder}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LeftDockTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Padding="6"
                                    Margin="0,0,0,6"
                                    Background="{StaticResource Brush.SurfaceSubtle}"
                                    BorderBrush="{StaticResource Brush.PanelBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <UniformGrid Rows="1" IsItemsHost="True" />
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              Margin="0,6,0,0"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LeftDockTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
            <Setter Property="Background" Value="{StaticResource Brush.ControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Margin="{TemplateBinding Margin}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EditorPrimaryToolbarCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}" Background="#FFFDF8" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EditorIconToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorPrimaryToolbarButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="EditorIconToolbarToggleStyle" TargetType="RadioButton" BasedOn="{StaticResource EditorPrimaryToolbarToggleStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="EditorIconToolbarCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource EditorPrimaryToolbarCheckBoxStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="DockIconButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactActionButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="DockIconCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource EditorPrimaryToolbarCheckBoxStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="StateLayerToggleStyle" TargetType="CheckBox" BasedOn="{StaticResource DockIconCheckBoxStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                Background="#FFFDF8"
                                BorderBrush="{StaticResource Brush.PanelBorder}"
                                BorderThickness="1"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StateOrderTextBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="90" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="ItemRemoveButtonStyle" TargetType="Button" BasedOn="{StaticResource DockIconButtonStyle}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="ImportedStateListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Padding="8,6"
                                Background="White"
                                BorderBrush="{StaticResource Brush.PanelBorder}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="Root" Property="Background" Value="#FFF9FFF9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarSymbolIconStyle" TargetType="{x:Type ui:SymbolIcon}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Filled" Value="True" />
        </Style>
        <Style x:Key="DockSymbolIconStyle" TargetType="{x:Type ui:SymbolIcon}" BasedOn="{StaticResource ToolbarSymbolIconStyle}" />
        <Style x:Key="LeftDockTabHeaderIconStyle" TargetType="{x:Type ui:SymbolIcon}" BasedOn="{StaticResource DockSymbolIconStyle}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="RailSymbolIconStyle" TargetType="{x:Type ui:SymbolIcon}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Filled" Value="False" />
        </Style>
        <Style x:Key="SidebarSectionBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="#FFFDF8EF" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="StateListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="Padding" Value="5,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}" Background="{StaticResource Brush.CardBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                                <Setter TargetName="Root" Property="Background" Value="#FFF6F1E8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFBF6EC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarDirectionListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}" Background="{StaticResource Brush.CardBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                                <Setter TargetName="Root" Property="Background" Value="#FFF6F1E8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFBF6EC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RailListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="IsEnabled" Value="{Binding IsAvailable}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DirectionNavigatorListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}" Background="{StaticResource Brush.SurfaceSubtle}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                                <Setter TargetName="Root" Property="Background" Value="#FFF6F1E8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFBF6EC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HorizontalDirectionStripListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}" Background="{StaticResource Brush.SurfaceSubtle}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                                <Setter TargetName="Root" Property="Background" Value="#FFF6F1E8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF8F2E6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ViewModeToggleRadioButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource ShellModeRadioButtonStyle}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Background" Value="{StaticResource Brush.ControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ViewportShellBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="2" />
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceSubtle}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="StatusTokenBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,6,3" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="{StaticResource Brush.CardBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style x:Key="StatusTokenLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        </Style>
        <Style x:Key="StatusTokenValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        </Style>
        <Style x:Key="EditorToolbarRadioButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource ShellModeRadioButtonStyle}">
            <Setter Property="Margin" Value="0,0,3,3" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
        <Style x:Key="IconToolbarToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,3,3" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}" Background="{StaticResource Brush.ControlBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavigatorActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="MinWidth" Value="72" />
        </Style>
        <DataTemplate x:Key="SourceCellTemplate">
            <Button Width="10" Height="10" Margin="0.25" Padding="0" Background="{Binding Fill}" BorderBrush="{Binding Border}" BorderThickness="1" Content="{Binding Caption}" Foreground="{Binding Foreground}" FontSize="6" ToolTip="{Binding ToolTip}" PreviewMouseLeftButtonDown="SourceCellButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="SourceCellButton_PreviewMouseLeftButtonUp" MouseEnter="SourceCellButton_MouseEnter" />
        </DataTemplate>
        <DataTemplate x:Key="TargetCellTemplate">
            <Button Width="10" Height="10" Margin="0.25" Padding="0" Background="{Binding Fill}" BorderBrush="{Binding Border}" BorderThickness="1" Content="{Binding Caption}" Foreground="{Binding Foreground}" FontSize="6" ToolTip="{Binding ToolTip}" PreviewMouseLeftButtonDown="TargetCellButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="TargetCellButton_PreviewMouseLeftButtonUp" MouseEnter="TargetCellButton_MouseEnter" />
        </DataTemplate>
        <DataTemplate x:Key="PreviewCellTemplate">
            <Border Width="8" Height="8" Margin="0.25" Background="{Binding Fill}" BorderBrush="{Binding Border}" BorderThickness="1" ToolTip="{Binding ToolTip}">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="5" Text="{Binding Caption}" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="DirectionNavigatorPreviewCellTemplate">
            <Border Width="4"
                    Height="4"
                    Margin="0"
                    Padding="0"
                    Background="{Binding Fill}"
                    BorderBrush="{Binding Border}"
                    BorderThickness="0"
                    ToolTip="{Binding ToolTip}" />
        </DataTemplate>
        <DataTemplate x:Key="DirectionNavigatorItemTemplate">
            <Grid MinHeight="56">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="56" Height="56" Padding="2" Background="#FFFFFCF7" CornerRadius="6">
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" />
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Label}" />
                    <TextBlock FontSize="10" Foreground="{StaticResource Brush.TextSecondary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Select direction" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Text" Value="Active direction" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="HorizontalDirectionStripItemTemplate">
            <Grid MinWidth="72" MinHeight="52">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Width="38" Height="38" HorizontalAlignment="Center" Padding="2" Background="#FFFFFCF7" CornerRadius="6">
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" />
                </Border>
                <TextBlock Grid.Row="1" Margin="0,4,0,0" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="{Binding Label}" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="SidebarDirectionItemTemplate">
            <Grid MinHeight="38" ToolTip="{Binding Label}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="28" Height="28" Padding="1" Background="#FFFFFCF7" CornerRadius="4">
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" />
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock FontSize="10" FontWeight="SemiBold" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="StateSidebarItemTemplate">
            <Grid MinHeight="46">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" Background="{StaticResource Brush.SurfaceSubtle}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="17">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" Text="S" />
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Text="{Binding}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="10" Foreground="{StaticResource Brush.TextSecondary}" Text="State layer" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="DirectionTileTemplate">
            <Border Margin="0,0,4,4" Padding="4" Background="{StaticResource Brush.CardBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Label}" />
                    <Grid Grid.Row="1" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="6" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Padding="3" Background="#FFF7FAFD" BorderBrush="#FFC7D3E4" BorderThickness="1" CornerRadius="7">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#FF4D627A" Text="Source" />
                                <Viewbox Grid.Row="1" Margin="0,3,0,0" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ItemsControl ItemsSource="{Binding SourceRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding Cells}" ItemTemplate="{StaticResource SourceCellTemplate}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Viewbox>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Padding="3" Background="#FFFFFAF3" BorderBrush="#FFD9BF9B" BorderThickness="1" CornerRadius="7">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#FF8B5C28" Text="Editable" />
                                <Viewbox Grid.Row="1" Margin="0,3,0,0" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ItemsControl ItemsSource="{Binding TargetRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding Cells}" ItemTemplate="{StaticResource TargetCellTemplate}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Viewbox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
        <HierarchicalDataTemplate x:Key="BatchSourceTreeItemTemplate" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" />
        </HierarchicalDataTemplate>
    </Window.Resources>

    <DockPanel Margin="6">
        <Border DockPanel.Dock="Bottom" Padding="8,5" Background="{StaticResource Brush.PanelBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditorSectionSelected}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid DataContext="{Binding OperationalStatusBar}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Text="{Binding StatusMessage}" />
                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush.TextSecondary}" Text="{Binding CurrentStateSummary}" />
                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush.TextSecondary}" Text="{Binding ActiveDirection, StringFormat=Dir {0}}" />
                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush.TextSecondary}" Text="{Binding MappingSummary}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{StaticResource Brush.TextSecondary}" Text="{Binding BatchSummary}" />
                    <ProgressBar Width="180" Height="8" Margin="0,0,10,0" VerticalAlignment="Center"
                                 IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                                 Maximum="{Binding OperationProgressMaximum, Mode=OneWay}"
                                 Value="{Binding OperationProgressValue, Mode=OneWay}" />
                    <Button Padding="10,4" Command="{Binding CancelCommand}" Content="Cancel" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CompactPanelBorderStyle}" Padding="6,8">
                <ListBox DataContext="{Binding NavigationRail}"
                         ItemsSource="{Binding Items}"
                         SelectedValuePath="Section"
                         SelectedValue="{Binding SelectedSection, Mode=TwoWay}"
                          Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource RailListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ToolTip="{Binding Label}"
                                  AutomationProperties.Name="{Binding Label}">
                                <ui:SymbolIcon Style="{StaticResource RailSymbolIconStyle}" HorizontalAlignment="Center" Symbol="{Binding IconSymbol}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="0,0,0,6">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ThinHeaderStripStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditorSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="20" Height="20" Margin="0,0,8,0" Source="pack://application:,,,/Assets/Brand/AdaptiveToolLogo.png" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="{Binding WorkspaceTitle}" />
                                <StackPanel Margin="0,1,0,0" Orientation="Horizontal">
                                    <TextBlock Foreground="{StaticResource Brush.TextSecondary}" Text="{Binding SpriteContractSummary}" />
                                    <TextBlock Margin="10,0,0,0" Foreground="{StaticResource Brush.TextSecondary}" Text="{Binding ConfigSummary}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Margin="0,0,6,0" Style="{StaticResource CompactActionButtonStyle}" Command="{Binding OpenDmiCommand}" Content="Open DMI" />
                            <Button Style="{StaticResource CompactActionButtonStyle}" Command="{Binding SaveConfigCommand}" Content="Save Config" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CompactPanelBorderStyle}">
                    <TabControl Style="{StaticResource ShellTabControlStyle}" SelectedIndex="{Binding SelectedShellSectionIndex, Mode=TwoWay}">
                <TabItem Header="Start">
                    <Grid DataContext="{Binding StartTab}" Margin="8">
                        <Border MaxWidth="488" Padding="16" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" Background="#FFF9F2" CornerRadius="18">
                            <StackPanel>
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding WelcomeTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource Brush.TextSecondary}" TextWrapping="Wrap" Text="{Binding WelcomeBody}" />
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding ResumeEditorHint}" />

                                <Button Margin="0,12,0,0" Command="{Binding ContinueToEditorCommand}" Content="Continue in Editor">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource StartPrimaryButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowContinueEditorAction}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Margin="0,12,0,0" Command="{Binding OpenDmiCommand}" Content="Open DMI">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource StartPrimaryButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowOpenDmiPrimaryAction}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Border Margin="0,10,0,0" Padding="10" Background="{StaticResource Brush.PanelBackground}" CornerRadius="12" Visibility="{Binding ShowCreateConfigAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource Brush.TextSecondary}" Text="Create a config for the loaded sprite" />
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Padding="12,7" Text="{Binding DraftConfigName, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="1" Width="140" Margin="10,0,0,0" Padding="12,7" Command="{Binding CreateConfigCommand}" Content="Create Config" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <UniformGrid Margin="0,8,0,0" Columns="3">
                                    <Button Margin="0,0,6,0" Command="{Binding OpenDmiCommand}" Content="Open DMI">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource StartSecondaryButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowCreateConfigAction}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Margin="0,0,6,0" Style="{StaticResource StartSecondaryButtonStyle}" Command="{Binding LoadConfigCommand}" Content="Load JSON" />
                                    <Button Margin="0" Style="{StaticResource StartSecondaryButtonStyle}" Command="{Binding ImportLegacyConfigCommand}" Content="Import CSV" />
                                </UniformGrid>

                                <Expander Margin="0,12,0,0" Header="Recent paths" Visibility="{Binding ShowRecentPaths, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Margin="0,8,0,0">
                                        <Button Padding="10,7" Command="{Binding ResumeLastWorkspaceCommand}" Content="Resume last workspace">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource StartSecondaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRecentWorkspace}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Margin="0,6,0,0" Padding="10,7" Command="{Binding OpenRecentDmiCommand}" IsEnabled="{Binding HasRecentDmi}">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Open last DMI" />
                                                <TextBlock Margin="0,2,0,0" Foreground="{StaticResource Brush.TextSecondary}" FontSize="12" TextWrapping="Wrap" Text="{Binding LastDmiPathSummary}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Margin="0,6,0,0" Padding="10,7" Command="{Binding OpenRecentConfigCommand}" IsEnabled="{Binding HasRecentConfig}">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Load last JSON config" />
                                                <TextBlock Margin="0,2,0,0" Foreground="{StaticResource Brush.TextSecondary}" FontSize="12" TextWrapping="Wrap" Text="{Binding LastConfigPathSummary}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Margin="0,6,0,0" Padding="10,7" Command="{Binding ImportRecentLegacyCsvCommand}" IsEnabled="{Binding HasRecentLegacyCsv}">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Import last legacy CSV" />
