                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Source set" />
                                <TreeView Grid.Row="1"
                                          Margin="0,10,0,0"
                                          ItemsSource="{Binding SourceTreeItems}"
                                          ItemTemplate="{StaticResource BatchSourceTreeItemTemplate}"
                                          SelectedItemChanged="BatchSourceTreeView_SelectedItemChanged" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Margin="0,0,10,0" Padding="10" Background="#FFF9F2" CornerRadius="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="States and quick preview" />
                                <TextBlock Grid.Row="1" Margin="0,6,0,0" Foreground="{StaticResource Brush.TextSecondary}" TextWrapping="Wrap" Text="{Binding BatchCurrentFile}" />
                                <ListBox Grid.Row="2"
                                         Margin="0,10,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         SelectedItem="{Binding SelectedStateStripItem, Mode=TwoWay}"
                                         ItemsSource="{Binding StateStripItems}">
                                    <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,8,8" Padding="8,5" Background="White" CornerRadius="10">
                                                <TextBlock FontSize="12" Text="{Binding Name}" />
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Border Grid.Row="3"
                                        Margin="0,2,0,0"
                                        Padding="10"
                                        Background="White"
                                        BorderBrush="{StaticResource Brush.PanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Padding="8"
                                                Background="#FFFEFCF6"
                                                BorderBrush="{StaticResource Brush.PanelBorder}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Text="Original" />
                                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                                    <Image Source="{Binding QuickPreviewOriginalImage}"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                           SnapsToDevicePixels="True">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasQuickPreviewOriginalImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource Brush.TextSecondary}"
                                                               Text="No original preview.">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasQuickPreviewOriginalImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Column="2"
                                                Padding="8"
                                                Background="#FFFEFCF6"
                                                BorderBrush="{StaticResource Brush.PanelBorder}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Text="Edited" />
                                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                                    <Image Source="{Binding QuickPreviewEditedImage}"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                           SnapsToDevicePixels="True">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasQuickPreviewEditedImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource Brush.TextSecondary}"
                                                               Text="No edited preview.">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasQuickPreviewEditedImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.ColumnSpan="3"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    MaxWidth="220">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasQuickPreview}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold" Text="Quick preview" />
                                            <TextBlock Margin="0,6,0,0"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding QuickPreviewSummary}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBlock Grid.Row="4"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Text="{Binding QuickPreviewSelectionSummary}" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Padding="10" Background="#FFF9F2" CornerRadius="16">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Configs and output" />
                                <TextBlock Grid.Row="1" Margin="0,6,0,0" Foreground="{StaticResource Brush.TextSecondary}" Text="{Binding BatchSummary}" />
                                <ListBox Grid.Row="2" Margin="0,10,0,0" ItemsSource="{Binding ConfigQueueItems}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8" Padding="10" Background="White" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                    <TextBlock Margin="0,2,0,0" Foreground="{StaticResource Brush.TextSecondary}" FontSize="12" Text="{Binding PathSummary}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0" Padding="10" Background="#FFF9F2" CornerRadius="16">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding BatchSummary}" />
                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource Brush.TextSecondary}" Text="{Binding BatchCurrentFile}" />
                                </StackPanel>
                                <DataGrid Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding BatchResults}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                                        <DataGridTextColumn Header="Input" Binding="{Binding InputPath}" Width="*" />
                                        <DataGridTextColumn Header="Output" Binding="{Binding OutputPath}" Width="*" />
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="1.25*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Settings">
                    <Grid DataContext="{Binding SettingsTab}" Margin="10">
                        <Border MaxWidth="560" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Top" Background="{StaticResource Brush.PanelBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="18">
                            <StackPanel>
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Shell Settings" />
                                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource Brush.TextSecondary}" TextWrapping="Wrap" Text="Presentation-only workspace preferences are stored separately from domain and batch logic." />

                                <Border Margin="0,14,0,0" Padding="12" Background="{StaticResource Brush.CardBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Appearance" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Text="Choose a saved shell color mode. Dark is the default workspace theme." />
                                        <ComboBox Margin="0,10,0,0"
                                                  Width="180"
                                                  ItemsSource="{Binding ThemeModes}"
                                                  SelectedItem="{Binding SelectedThemeMode}" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,12,0,0" Padding="12" Background="{StaticResource Brush.CardBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Editor viewport" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Text="Matrix is the default parity path. Focused mode stays experimental until parity is complete." />
                                        <ComboBox Margin="0,10,0,0" Width="180" ItemsSource="{Binding ViewportModes}" SelectedItem="{Binding SelectedViewportMode}" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,12,0,0" Padding="12" Background="{StaticResource Brush.CardBackground}" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Workspace panels" />
                                        <CheckBox Margin="0,10,0,0" IsChecked="{Binding IsPreviewInspectorExpanded}" Content="Preview inspector starts expanded" />
                                        <CheckBox Margin="0,8,0,0" IsChecked="{Binding IsBottomWorkspaceExpanded}" Content="Bottom workspace panels stay expanded" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,14,0,0" Padding="0,10,0,0" BorderBrush="{StaticResource Brush.PanelBorder}" BorderThickness="0,1,0,0">
                                    <Button Width="160" Padding="12,8" HorizontalAlignment="Left" Command="{Binding DataContext.ResetWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}" Content="Reset Workspace" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
