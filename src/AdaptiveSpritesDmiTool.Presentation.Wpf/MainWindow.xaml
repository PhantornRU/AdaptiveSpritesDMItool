                                                <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding ActiveDirectionLabel}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource StatusTokenBorderStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="Asset:" />
