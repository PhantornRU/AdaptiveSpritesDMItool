                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="{DynamicResource Text.Token.Mappings}" />
                                                <TextBlock Margin="4,0,0,0"
                                                           Style="{StaticResource StatusTokenValueStyle}"
                                                           Text="{Binding MappingCountToken}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource StatusTokenBorderStyle}">
                                            <TextBlock Style="{StaticResource StatusTokenValueStyle}" Text="{Binding DraftToken}" />
                                        </Border>
                                        <Border Style="{StaticResource StatusTokenBorderStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="{DynamicResource Text.Token.Zoom}" />
                                                <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding ActiveEditorZoomLabel}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Grid.ColumnSpan="5" Margin="0,4,0,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="236" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="156" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{DynamicResource Brush.PanelBackground}"
                                    CornerRadius="8"
                                    Visibility="{Binding ShowEditorLeftRail, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Border Grid.Column="4"
                                    Background="{DynamicResource Brush.PanelBackground}"
                                    CornerRadius="8"
                                    Visibility="{Binding ShowRightDirectionStrip, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Border Grid.Column="2"
                                    Padding="8,3"
                                    MinHeight="30"
                                    Background="{DynamicResource Brush.PanelBackground}"
                                    BorderBrush="{DynamicResource Brush.PanelBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding ShowBottomStatusBar, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <WrapPanel VerticalAlignment="Center">
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="{DynamicResource Text.Token.Dir}" />
                                            <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding ActiveDirectionLabel}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="{DynamicResource Text.Token.Asset}" />
                                            <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding CurrentAssetDisplayName}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="{DynamicResource Text.Token.Hover}" />
                                            <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding HoverToken}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="{DynamicResource Text.Token.Mapping}" />
                                            <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding HoverMappingToken}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="{DynamicResource Text.Token.Config}" />
                                            <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding ConfigToken}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="{DynamicResource Text.Token.Mappings}" />
                                            <TextBlock Margin="4,0,0,0"
                                                       Style="{StaticResource StatusTokenValueStyle}"
                                                       Text="{Binding MappingCountToken}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <TextBlock Style="{StaticResource StatusTokenValueStyle}" Text="{Binding DraftToken}" />
                                    </Border>
                                    <Border Style="{StaticResource StatusTokenBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource StatusTokenLabelStyle}" Text="{DynamicResource Text.Token.Zoom}" />
                                            <TextBlock Margin="4,0,0,0" Style="{StaticResource StatusTokenValueStyle}" Text="{Binding ActiveEditorZoomLabel}" />
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource Text.Tab.Data}" IsEnabled="{Binding BatchWorkspace.IsAvailable}">
                    <views:BatchWorkspaceView DataContext="{Binding BatchWorkspace}" />
                </TabItem>
                <TabItem Header="{DynamicResource Text.Tab.Settings}">
                    <Grid DataContext="{Binding SettingsTab}" Margin="10">
                        <Border MaxWidth="560" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Top" Background="{DynamicResource Brush.PanelBackground}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="18">
                            <StackPanel>
                                <TextBlock FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           Text="{DynamicResource Text.Settings.Title}" />
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap" Text="{DynamicResource Text.Settings.Description}" />

                                <Border Margin="0,14,0,0" Padding="12" Background="{DynamicResource Brush.CardBackground}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   Text="{DynamicResource Text.Settings.Appearance}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Text="{DynamicResource Text.Settings.AppearanceDescription}" />
                                        <ComboBox Style="{StaticResource ThemedComboBoxStyle}"
                                                  Margin="0,10,0,0"
                                                  Width="180"
                                                  SelectedValue="{Binding SelectedThemeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag">
                                            <ComboBoxItem Tag="{x:Static local:WorkspaceThemeMode.Dark}" Content="{DynamicResource Text.Theme.Dark}" />
                                            <ComboBoxItem Tag="{x:Static local:WorkspaceThemeMode.Light}" Content="{DynamicResource Text.Theme.Light}" />
                                            <ComboBoxItem Tag="{x:Static local:WorkspaceThemeMode.Warm}" Content="{DynamicResource Text.Theme.Warm}" />
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,12,0,0" Padding="12" Background="{DynamicResource Brush.CardBackground}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   Text="{DynamicResource Text.Settings.Language}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Text="{DynamicResource Text.Settings.LanguageDescription}" />
                                        <ComboBox Style="{StaticResource ThemedComboBoxStyle}"
                                                  Margin="0,10,0,0"
                                                  Width="180"
                                                  SelectedValue="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag">
                                            <ComboBoxItem Tag="{x:Static local:WorkspaceLanguage.English}" Content="{DynamicResource Text.Language.English}" />
                                            <ComboBoxItem Tag="{x:Static local:WorkspaceLanguage.Russian}" Content="{DynamicResource Text.Language.Russian}" />
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,12,0,0" Padding="12" Background="{DynamicResource Brush.CardBackground}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   Text="{DynamicResource Text.Settings.EditorViewport}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Text="{DynamicResource Text.Settings.EditorViewportDescription}" />
                                        <ComboBox Style="{StaticResource ThemedComboBoxStyle}"
                                                  Margin="0,10,0,0"
                                                  Width="180"
                                                  SelectedValue="{Binding SelectedViewportMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag">
                                            <ComboBoxItem Tag="{x:Static local:EditorViewportMode.Matrix}" Content="{DynamicResource Text.Viewport.Matrix}" />
                                            <ComboBoxItem Tag="{x:Static local:EditorViewportMode.Focused}" Content="{DynamicResource Text.Viewport.Focused}" />
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,12,0,0" Padding="12" Background="{DynamicResource Brush.CardBackground}" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1" CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   Text="{DynamicResource Text.Settings.WorkspacePanels}" />
                                        <CheckBox Style="{StaticResource ThemedCheckBoxStyle}" Margin="0,10,0,0" IsChecked="{Binding IsPreviewInspectorExpanded}" Content="{DynamicResource Text.Settings.PreviewInspectorExpanded}" />
                                        <CheckBox Style="{StaticResource ThemedCheckBoxStyle}" Margin="0,8,0,0" IsChecked="{Binding IsBottomWorkspaceExpanded}" Content="{DynamicResource Text.Settings.BottomPanelsExpanded}" />
                                        <CheckBox Style="{StaticResource ThemedCheckBoxStyle}" Margin="0,8,0,0" IsChecked="{Binding HideInactiveSourceCanvases}" Content="{DynamicResource Text.Settings.HideInactiveSourceCanvases}" />
                                        <CheckBox Style="{StaticResource ThemedCheckBoxStyle}" Margin="0,8,0,0" IsChecked="{Binding FitMultipleDirectionCanvasesToViewport}" Content="{DynamicResource Text.Settings.FitMultipleDirectionCanvases}" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,14,0,0" Padding="0,10,0,0" BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="0,1,0,0">
                                    <Button Style="{StaticResource ThemedButtonStyle}" Width="190" Padding="12,8" HorizontalAlignment="Left" Command="{Binding DataContext.ResetWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}" Content="{DynamicResource Text.Settings.ResetWorkspace}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>

