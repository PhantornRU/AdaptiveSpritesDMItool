<Application x:Class="AdaptiveSpritesDmiTool.Presentation.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <FontFamily x:Key="FluentSystemIcons">pack://application:,,,/Wpf.Ui;component/Resources/Fonts/#FluentSystemIcons-Regular</FontFamily>
            <FontFamily x:Key="FluentSystemIconsFilled">pack://application:,,,/Wpf.Ui;component/Resources/Fonts/#FluentSystemIcons-Filled</FontFamily>
            <Style TargetType="{x:Type ui:SymbolIcon}">
                <Setter Property="Filled" Value="False" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            </Style>
            <SolidColorBrush x:Key="Brush.WindowBackground" po:Freeze="False" Color="#171A1F" />
            <SolidColorBrush x:Key="Brush.PanelBackground" po:Freeze="False" Color="#1F252D" />
            <SolidColorBrush x:Key="Brush.PanelBorder" po:Freeze="False" Color="#39424D" />
            <SolidColorBrush x:Key="Brush.Accent" po:Freeze="False" Color="#2D8C7F" />
            <SolidColorBrush x:Key="Brush.AccentMuted" po:Freeze="False" Color="#2A4D49" />
            <SolidColorBrush x:Key="Brush.Warning" po:Freeze="False" Color="#D88B3D" />
            <SolidColorBrush x:Key="Brush.TextPrimary" po:Freeze="False" Color="#F4F1EA" />
            <SolidColorBrush x:Key="Brush.TextSecondary" po:Freeze="False" Color="#B6C0CA" />
            <SolidColorBrush x:Key="Brush.ControlBackground" po:Freeze="False" Color="#252C35" />
            <SolidColorBrush x:Key="Brush.CardBackground" po:Freeze="False" Color="#232A33" />
            <SolidColorBrush x:Key="Brush.SurfaceSubtle" po:Freeze="False" Color="#202730" />
            <SolidColorBrush x:Key="Brush.ScrollTrack" po:Freeze="False" Color="#1B2129" />
            <SolidColorBrush x:Key="Brush.ScrollThumb" po:Freeze="False" Color="#4A5968" />
            <SolidColorBrush x:Key="Brush.ScrollThumbHover" po:Freeze="False" Color="#5D6F82" />
            <SolidColorBrush x:Key="Brush.ScrollThumbPressed" po:Freeze="False" Color="#7691AC" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
