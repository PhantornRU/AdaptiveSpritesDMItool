<UserControl
    x:Class="AdaptiveSpritesDmiTool.Presentation.Wpf.Views.BatchWorkspaceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AdaptiveSpritesDmiTool.Presentation.Wpf"
    MinWidth="900"
    MinHeight="520"
    Background="{DynamicResource Brush.PanelBackground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:OverwritePolicyLabelConverter x:Key="OverwritePolicyLabelConverter" />

        <SolidColorBrush
            x:Key="{x:Static SystemColors.WindowBrushKey}"
            Color="{DynamicResource Color.ControlBackground}" />
        <SolidColorBrush
            x:Key="{x:Static SystemColors.ControlBrushKey}"
            Color="{DynamicResource Color.ControlBackground}" />
        <SolidColorBrush
            x:Key="{x:Static SystemColors.ControlTextBrushKey}"
            Color="{DynamicResource Color.TextPrimary}" />
        <SolidColorBrush
            x:Key="{x:Static SystemColors.WindowTextBrushKey}"
            Color="{DynamicResource Color.TextPrimary}" />
        <SolidColorBrush
            x:Key="{x:Static SystemColors.HighlightBrushKey}"
            Color="{DynamicResource Color.AccentMuted}" />
        <SolidColorBrush
            x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
            Color="{DynamicResource Color.TextPrimary}" />
        <SolidColorBrush
            x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
            Color="{DynamicResource Color.AccentMuted}" />
        <SolidColorBrush
            x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
            Color="{DynamicResource Color.TextPrimary}" />
        <SolidColorBrush
            x:Key="{x:Static SystemColors.GrayTextBrushKey}"
            Color="{DynamicResource Color.TextSecondary}" />

        <Style x:Key="BatchCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource Brush.CardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="BatchSectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="BatchLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="BatchMutedText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="BatchPathBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="BatchButtonBase" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                RecognizesAccessKey="True" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.AccentMuted}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
                                <Setter Property="Opacity" Value="0.48" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="BatchFlatButton"
            TargetType="{x:Type Button}"
            BasedOn="{StaticResource BatchButtonBase}" />

        <Style
            x:Key="BatchPrimaryButton"
            TargetType="{x:Type Button}"
            BasedOn="{StaticResource BatchButtonBase}">
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="BatchComboBoxItem" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.AccentMuted}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.AccentMuted}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatchComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource BatchComboBoxItem}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton
                                x:Name="ToggleButton"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClickMode="Press"
                                Focusable="False"
                                IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border
                                            x:Name="Root"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="26" />
                                                </Grid.ColumnDefinitions>

                                                <Path
                                                    Grid.Column="1"
                                                    Width="8"
                                                    Height="5"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Data="M 0 0 L 4 5 L 8 0 Z"
                                                    Fill="{DynamicResource Brush.TextSecondary}" />
                                            </Grid>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter
                                x:Name="ContentSite"
                                Margin="8,0,28,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                IsHitTestVisible="False" />

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Fade">
                                <Border
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{DynamicResource Brush.ControlBackground}"
                                    BorderBrush="{DynamicResource Brush.PanelBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True">
                                    <ScrollViewer
                                        CanContentScroll="True"
                                        Background="{DynamicResource Brush.ControlBackground}">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup" Property="MinHeight" Value="32" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TreeView}">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style TargetType="{x:Type TreeViewItem}">
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="Padding" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border
                            x:Name="Root"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.AccentMuted}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatchDataGridColumnHeader" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="BatchDataGridCell" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter
                                Margin="6,0"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.AccentMuted}" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchDataGridRow" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.AccentMuted}" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchResultsGrid" TargetType="{x:Type DataGrid}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowHeight" Value="26" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource BatchDataGridColumnHeader}" />
            <Setter Property="CellStyle" Value="{StaticResource BatchDataGridCell}" />
            <Setter Property="RowStyle" Value="{StaticResource BatchDataGridRow}" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
        </Style>

        <Style x:Key="BatchResultsGridWithVisibility" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource BatchResultsGrid}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasNoBatchResults}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchGridTextBlock" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="BatchGridStatusTextBlock" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource BatchGridTextBlock}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusText}" Value="Processed">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="Failed">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Warning}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="Cancelled">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchResultsPlaceholder" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasNoBatchResults}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate
            DataType="{x:Type local:BatchSourceTreeItemViewModel}"
            ItemsSource="{Binding Children}">
            <Grid ToolTip="{Binding FullPath}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{DynamicResource Brush.TextPrimary}" />

                <TextBlock
                    Grid.Column="1"
                    Text="!"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.Warning}"
                    ToolTip="{Binding ValidationMessage}"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Opacity" Value="0.85" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type local:BatchStateStripItemViewModel}">
            <TextBlock
                Text="{Binding Name}"
                TextTrimming="CharacterEllipsis"
                Foreground="{DynamicResource Brush.TextPrimary}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid
        Margin="10"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="340" />
            <RowDefinition Height="170" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Style="{StaticResource BatchCard}"
            Padding="10"
            Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="82" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="82" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Source folder" Style="{StaticResource BatchLabel}" />
                        <TextBox
                            Style="{StaticResource BatchPathBox}"
                            Text="{Binding BatchInputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Button
                        Grid.Column="1"
                        Content="Browse"
                        Command="{Binding BrowseBatchInputDirectoryCommand}"
                        Style="{StaticResource BatchFlatButton}" />

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Output folder" Style="{StaticResource BatchLabel}" />
                        <TextBox
                            Style="{StaticResource BatchPathBox}"
                            Text="{Binding BatchOutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Button
                        Grid.Column="4"
                        Content="Browse"
                        Command="{Binding BrowseBatchOutputDirectoryCommand}"
                        Style="{StaticResource BatchFlatButton}" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="88" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis">
                        <Run Text="Config: " Foreground="{DynamicResource Brush.TextSecondary}" />
                        <Run Text="{Binding ActiveConfigName, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" />
                        <Run Text="  -  " Foreground="{DynamicResource Brush.TextSecondary}" />
                        <Run Text="Current: " Foreground="{DynamicResource Brush.TextSecondary}" />
                        <Run Text="{Binding CurrentFileSummary, Mode=OneWay}" Foreground="{DynamicResource Brush.TextSecondary}" />
                    </TextBlock>

                    <ComboBox
                        Grid.Column="1"
                        Margin="0,0,8,0"
                        Style="{StaticResource BatchComboBox}"
                        ItemsSource="{Binding OverwritePolicies}"
                        SelectedItem="{Binding SelectedOverwritePolicy, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding Converter={StaticResource OverwritePolicyLabelConverter}}"
                                    Foreground="{DynamicResource Brush.TextPrimary}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button
                        Grid.Column="2"
                        Margin="0,0,8,0"
                        Content="Run batch"
                        Command="{Binding RunBatchCommand}"
                        Style="{StaticResource BatchPrimaryButton}" />

                    <Button
                        Grid.Column="3"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsBusy}"
                        Style="{StaticResource BatchFlatButton}" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" MinWidth="340" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="620" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Style="{StaticResource BatchCard}"
                Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Text="Source files"
                            Style="{StaticResource BatchSectionTitle}" />

                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding SourceSelectionDetail}"
                            Style="{StaticResource BatchMutedText}"
                            HorizontalAlignment="Right"
                            Margin="12,0,0,0" />
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock
                            Text="{Binding SourceSelectionName}"
                            Foreground="{DynamicResource Brush.TextPrimary}"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Text="{Binding SourceSelectionPath}"
                            Style="{StaticResource BatchMutedText}" />
                    </StackPanel>

                    <TreeView
                        x:Name="BatchSourceTreeView"
                        Grid.Row="2"
                        ItemsSource="{Binding SourceTreeItems}"
                        SelectedItemChanged="BatchSourceTreeView_SelectedItemChanged" />
                </Grid>
            </Border>

            <GridSplitter
                Grid.Column="1"
                Width="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                ResizeDirection="Columns"
                ResizeBehavior="PreviousAndNext" />

            <Border
                Grid.Column="2"
                Style="{StaticResource BatchCard}"
                Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Text="Preview"
                            Style="{StaticResource BatchSectionTitle}" />

                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding QuickPreviewSummary}"
                            Style="{StaticResource BatchMutedText}"
                            HorizontalAlignment="Right"
                            Margin="12,0,0,0" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Text="States"
                                Style="{StaticResource BatchLabel}" />

                            <ListBox
                                Grid.Row="1"
                                ItemsSource="{Binding StateStripItems}"
                                SelectedItem="{Binding SelectedStateStripItem, Mode=TwoWay}" />
                        </Grid>

                        <Border
                            Grid.Column="2"
                            Style="{StaticResource BatchCard}"
                            Background="{DynamicResource Brush.SurfaceSubtle}"
                            Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Text="Original"
                                    Style="{StaticResource BatchSectionTitle}"
                                    Margin="0,0,0,8" />

                                <Image
                                    Grid.Row="1"
                                    Source="{Binding QuickPreviewOriginalImage}"
                                    Stretch="Uniform"
                                    MaxWidth="340"
                                    MaxHeight="320"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    SnapsToDevicePixels="True" />
                            </Grid>
                        </Border>

                        <Border
                            Grid.Column="4"
                            Style="{StaticResource BatchCard}"
                            Background="{DynamicResource Brush.SurfaceSubtle}"
                            Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Text="Edited"
                                    Style="{StaticResource BatchSectionTitle}"
                                    Margin="0,0,0,8" />

                                <Image
                                    Grid.Row="1"
                                    Source="{Binding QuickPreviewEditedImage}"
                                    Stretch="Uniform"
                                    MaxWidth="340"
                                    MaxHeight="320"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    SnapsToDevicePixels="True" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border
            Grid.Row="2"
            Style="{StaticResource BatchCard}"
            Margin="0,8,0,0"
            Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel
                    Grid.Row="0"
                    LastChildFill="True"
                    Margin="10,0">
                    <TextBlock
                        DockPanel.Dock="Left"
                        Text="Results"
                        Style="{StaticResource BatchSectionTitle}"
                        Margin="0,0,10,0" />

                    <TextBlock
                        DockPanel.Dock="Left"
                        Text="{Binding BatchSummary}"
                        Style="{StaticResource BatchMutedText}" />

                    <TextBlock
                        DockPanel.Dock="Right"
                        Foreground="{DynamicResource Brush.TextSecondary}"
                        FontSize="12"
                        VerticalAlignment="Center">
                        <Run Text="Done " />
                        <Run Text="{Binding ProcessedResultCount, Mode=OneWay}" />
                        <Run Text="  |  Skip " />
                        <Run Text="{Binding SkippedResultCount, Mode=OneWay}" />
                        <Run Text="  |  Fail " />
                        <Run Text="{Binding FailedResultCount, Mode=OneWay}" />
                        <Run Text="  |  Cancel " />
                        <Run Text="{Binding CancelledResultCount, Mode=OneWay}" />
                    </TextBlock>
                </DockPanel>

                <Grid Grid.Row="1">
                    <DataGrid
                        ItemsSource="{Binding BatchResults}"
                        Style="{StaticResource BatchResultsGridWithVisibility}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Header="Status"
                                Binding="{Binding StatusText}"
                                Width="96"
                                ElementStyle="{StaticResource BatchGridStatusTextBlock}" />

                            <DataGridTextColumn
                                Header="Input"
                                Binding="{Binding InputPath}"
                                Width="2*"
                                ElementStyle="{StaticResource BatchGridTextBlock}" />

                            <DataGridTextColumn
                                Header="Output"
                                Binding="{Binding OutputPath}"
                                Width="2*"
                                ElementStyle="{StaticResource BatchGridTextBlock}" />

                            <DataGridTextColumn
                                Header="Message"
                                Binding="{Binding Message}"
                                Width="2*"
                                ElementStyle="{StaticResource BatchGridTextBlock}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock
                        Text="No batch results yet. Run batch to populate this table."
                        Style="{StaticResource BatchResultsPlaceholder}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
