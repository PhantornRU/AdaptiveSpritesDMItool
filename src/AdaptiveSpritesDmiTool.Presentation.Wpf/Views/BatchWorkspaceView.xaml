<UserControl
    x:Class="AdaptiveSpritesDmiTool.Presentation.Wpf.Views.BatchWorkspaceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AdaptiveSpritesDmiTool.Presentation.Wpf"
    MinWidth="900"
    MinHeight="520"
    Background="{DynamicResource Brush.PanelBackground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="BatchCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource Brush.CardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="BatchSectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="BatchLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="BatchMutedText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="BatchPathBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="BatchFlatButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
        </Style>

        <Style x:Key="BatchPrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource BatchFlatButton}">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="BatchComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
        </Style>

        <Style TargetType="{x:Type TreeView}">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style TargetType="{x:Type TreeViewItem}">
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="Padding" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <HierarchicalDataTemplate
            DataType="{x:Type local:BatchSourceTreeItemViewModel}"
            ItemsSource="{Binding Children}">
            <DockPanel
                LastChildFill="True"
                ToolTip="{Binding FullPath}">
                <TextBlock
                    DockPanel.Dock="Right"
                    Text="!"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.Warning}"
                    ToolTip="{Binding ValidationMessage}"
                    Margin="6,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{DynamicResource Brush.TextPrimary}" />
            </DockPanel>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type local:BatchStateStripItemViewModel}">
            <TextBlock
                Text="{Binding Name}"
                TextTrimming="CharacterEllipsis"
                Foreground="{DynamicResource Brush.TextPrimary}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="184" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Style="{StaticResource BatchCard}"
            Padding="10"
            Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="154" />
                    <ColumnDefinition Width="104" />
                    <ColumnDefinition Width="86" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Source folder" Style="{StaticResource BatchLabel}" />
                    <TextBox
                        Style="{StaticResource BatchPathBox}"
                        Text="{Binding BatchInputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Content="Browse"
                    Command="{Binding BrowseBatchInputDirectoryCommand}"
                    Style="{StaticResource BatchFlatButton}" />

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,8,0">
                    <TextBlock Text="Output folder" Style="{StaticResource BatchLabel}" />
                    <TextBox
                        Style="{StaticResource BatchPathBox}"
                        Text="{Binding BatchOutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button
                    Grid.Row="0"
                    Grid.Column="3"
                    Content="Browse"
                    Command="{Binding BrowseBatchOutputDirectoryCommand}"
                    Style="{StaticResource BatchFlatButton}" />

                <StackPanel Grid.Row="0" Grid.Column="4" Margin="10,0,8,0">
                    <TextBlock Text="Overwrite policy" Style="{StaticResource BatchLabel}" />
                    <ComboBox
                        Style="{StaticResource BatchComboBox}"
                        ItemsSource="{Binding OverwritePolicies}"
                        SelectedItem="{Binding SelectedOverwritePolicy, Mode=TwoWay}" />
                </StackPanel>

                <Button
                    Grid.Row="0"
                    Grid.Column="5"
                    Content="Run batch"
                    Command="{Binding RunBatchCommand}"
                    Style="{StaticResource BatchPrimaryButton}" />

                <Button
                    Grid.Row="0"
                    Grid.Column="6"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource BatchFlatButton}" />

                <DockPanel
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="7"
                    Margin="0,8,0,0"
                    LastChildFill="True">
                    <TextBlock
                        DockPanel.Dock="Left"
                        Text="Config:"
                        Style="{StaticResource BatchMutedText}"
                        Margin="0,0,4,0" />

                    <TextBlock
                        DockPanel.Dock="Left"
                        Text="{Binding ActiveConfigName}"
                        Foreground="{DynamicResource Brush.TextPrimary}"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis"
                        Margin="0,0,6,0" />

                    <TextBlock
                        DockPanel.Dock="Left"
                        Text="{Binding ActiveConfigStorage}"
                        Style="{StaticResource BatchMutedText}"
                        Margin="0,0,20,0" />

                    <TextBlock
                        DockPanel.Dock="Left"
                        Text="Current:"
                        Style="{StaticResource BatchMutedText}"
                        Margin="0,0,4,0" />

                    <TextBlock
                        Text="{Binding CurrentFileSummary}"
                        Style="{StaticResource BatchMutedText}" />
                </DockPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Style="{StaticResource BatchCard}"
                Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <TextBlock
                            Text="Source files"
                            Style="{StaticResource BatchSectionTitle}" />
                        <TextBlock
                            DockPanel.Dock="Right"
                            Text="{Binding SourceSelectionDetail}"
                            Style="{StaticResource BatchMutedText}" />
                    </DockPanel>

                    <StackPanel Grid.Row="1" Margin="0,4,0,8">
                        <TextBlock
                            Text="{Binding SourceSelectionName}"
                            Foreground="{DynamicResource Brush.TextPrimary}"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Text="{Binding SourceSelectionPath}"
                            Style="{StaticResource BatchMutedText}" />
                    </StackPanel>

                    <TreeView
                        x:Name="BatchSourceTreeView"
                        Grid.Row="2"
                        ItemsSource="{Binding SourceTreeItems}"
                        SelectedItemChanged="BatchSourceTreeView_SelectedItemChanged" />
                </Grid>
            </Border>

            <Border
                Grid.Column="2"
                Style="{StaticResource BatchCard}"
                Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
                        <TextBlock
                            Text="Preview"
                            Style="{StaticResource BatchSectionTitle}" />
                        <TextBlock
                            DockPanel.Dock="Right"
                            Text="{Binding QuickPreviewSummary}"
                            Style="{StaticResource BatchMutedText}" />
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Text="States"
                                Style="{StaticResource BatchLabel}" />

                            <ListBox
                                Grid.Row="1"
                                ItemsSource="{Binding StateStripItems}"
                                SelectedItem="{Binding SelectedStateStripItem, Mode=TwoWay}" />
                        </Grid>

                        <Border
                            Grid.Column="2"
                            Style="{StaticResource BatchCard}"
                            Background="{DynamicResource Brush.SurfaceSubtle}"
                            Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Text="Original"
                                    Style="{StaticResource BatchSectionTitle}"
                                    Margin="0,0,0,8" />

                                <Image
                                    Grid.Row="1"
                                    Source="{Binding QuickPreviewOriginalImage}"
                                    Stretch="Uniform"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    SnapsToDevicePixels="True" />
                            </Grid>
                        </Border>

                        <Border
                            Grid.Column="4"
                            Style="{StaticResource BatchCard}"
                            Background="{DynamicResource Brush.SurfaceSubtle}"
                            Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Text="Edited"
                                    Style="{StaticResource BatchSectionTitle}"
                                    Margin="0,0,0,8" />

                                <Image
                                    Grid.Row="1"
                                    Source="{Binding QuickPreviewEditedImage}"
                                    Stretch="Uniform"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    SnapsToDevicePixels="True" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border
            Grid.Row="2"
            Style="{StaticResource BatchCard}"
            Margin="0,8,0,0"
            Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel
                    Grid.Row="0"
                    LastChildFill="True"
                    Margin="10,0">
                    <TextBlock
                        DockPanel.Dock="Left"
                        Text="Results"
                        Style="{StaticResource BatchSectionTitle}"
                        Margin="0,0,10,0" />

                    <TextBlock
                        DockPanel.Dock="Left"
                        Text="{Binding BatchSummary}"
                        Style="{StaticResource BatchMutedText}" />

                    <TextBlock
                        DockPanel.Dock="Right"
                        Foreground="{DynamicResource Brush.TextSecondary}"
                        FontSize="12"
                        VerticalAlignment="Center">
                        <Run Text="Done " />
                        <Run Text="{Binding ProcessedResultCount, Mode=OneWay}" />
                        <Run Text="  |  Skip " />
                        <Run Text="{Binding SkippedResultCount, Mode=OneWay}" />
                        <Run Text="  |  Fail " />
                        <Run Text="{Binding FailedResultCount, Mode=OneWay}" />
                        <Run Text="  |  Cancel " />
                        <Run Text="{Binding CancelledResultCount, Mode=OneWay}" />
                    </TextBlock>
                </DockPanel>

                <DataGrid
                    Grid.Row="1"
                    ItemsSource="{Binding BatchResults}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserResizeRows="False"
                    HeadersVisibility="Column"
                    GridLinesVisibility="Horizontal"
                    RowHeight="24"
                    BorderThickness="0"
                    Background="{DynamicResource Brush.SurfaceSubtle}"
                    Foreground="{DynamicResource Brush.TextPrimary}"
                    HorizontalGridLinesBrush="{DynamicResource Brush.PanelBorder}"
                    VerticalGridLinesBrush="{DynamicResource Brush.PanelBorder}"
                    EnableRowVirtualization="True"
                    EnableColumnVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Header="Status"
                            Binding="{Binding StatusText}"
                            Width="90" />

                        <DataGridTextColumn
                            Header="Input"
                            Binding="{Binding InputPath}"
                            Width="2*" />

                        <DataGridTextColumn
                            Header="Output"
                            Binding="{Binding OutputPath}"
                            Width="2*" />

                        <DataGridTextColumn
                            Header="Message"
                            Binding="{Binding Message}"
                            Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
